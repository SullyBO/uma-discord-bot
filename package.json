{
  "name": "uma-discord-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "deploy:dev": "cross-env NODE_ENV=development ts-node src/deploy-commands.ts",
    "deploy:prod": "cross-env NODE_ENV=production ts-node src/deploy-commands.ts",
    "format": "prettier --write src/**/*.ts",
    "lint": "eslint src/**/*.ts",
    "prepare": "husky",
    "test": "cross-env NODE_ENV=development vitest",
    "test:run": "cross-env NODE_ENV=development vitest run",
    "test:coverage": "cross-env NODE_ENV=development vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "dotenv-flow": "^4.1.0"
  },
  "devDependencies": {
    "@types/dotenv-flow": "^3.3.3",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^8.20.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
